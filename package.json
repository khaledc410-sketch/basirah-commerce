{
  "name": "basirah-commerce",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "node --conditions=react-server --import tsx src/workers/visibility-worker.ts",
    "worker:visibility": "node --conditions=react-server --import tsx src/workers/visibility-worker.ts",
    "worker:catalog": "node --conditions=react-server --import tsx src/workers/catalog-worker.ts",
    "report:fulfill": "node --conditions=react-server --import tsx src/cli/fulfill-report-order.ts",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run db:check && APP_MODE=demo npm run build"
  },
  "dependencies": {
